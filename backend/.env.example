# =====================================================
# MDA - Mimos de Alice | Mimos Hub
# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# =====================================================

# ─── Banco de Dados ───
# URL de conexão PostgreSQL (asyncpg para FastAPI async)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE

# ─── JWT / Autenticação ───
# Chave secreta para assinatura de tokens JWT
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-muito-longa-e-segura-aqui

# Algoritmo de criptografia JWT
ALGORITHM=HS256

# Tempo de expiração do token em minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Segurança ───
# Chave secreta para proteger endpoint de registro de usuários
# Se vazio, o registro fica aberto (NÃO RECOMENDADO em produção)
# Gerar com: python -c "import secrets; print(secrets.token_hex(16))"
REGISTRATION_SECRET_KEY=

# Forçar HTTPS em produção (redireciona HTTP -> HTTPS)
FORCE_HTTPS=false

# ─── Usuário Padrão (seed) ───
# Credenciais do usuário criado automaticamente na primeira execução
DEFAULT_USER_EMAIL=admin@seudominio.com.br
DEFAULT_USER_PASSWORD=senha-segura-aqui
DEFAULT_USER_NAME=Administrador

# ─── Z-API (WhatsApp) ───
# Credenciais da instância Z-API para envio de mensagens
# Obter em: https://z-api.io/
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ─── CORS ───
# Origens permitidas para requisições cross-origin
# Separar múltiplas origens por vírgula
CORS_ORIGINS=http://localhost:5173

# ─── Frontend URL ───
# URL base do frontend (usado para gerar links nas mensagens WhatsApp)
FRONTEND_URL=http://localhost:5173
